{
  "name": "yt-downloader",
  "version": "0.1.0",
  "description": "A standalone Windows app for downloading YouTube video, audio, playlists, thumbnails, subtitles, metadata, and clips.",
  "author": "ahsaniftikharofficial-prog",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "setup": "node scripts/setup-ffmpeg.js && node scripts/setup-ytdlp.js && node scripts/setup-deno.js",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.ahsaniftikhar.xebecdownloader",
    "productName": "Xebec Downloader",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ahsaniftikharofficial-prog",
        "repo": "Xebec-Downlaoder",
        "releaseType": "release"
      }
    ]
  }
}
